# Aegis — Environment Variables
# Copy to .env and fill in values. Never commit .env.
#
# Required for live Linear workspace scans (Phase 2+):
#   LINEAR_API_KEY → from Linear Settings > Security & access > Personal API keys
#   Create a key with "Read" scope minimum. "Write" scope needed in Phase 4 (Executor).
#   Without this key, Signal Engine uses MockLinearMCP (safe for evals + local dev).
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Force MockLinearMCP even when LINEAR_API_KEY is set (e.g. CI/CD eval runs).
# Set to "true" to use fixture data instead of live Linear API.
AEGIS_MOCK_LINEAR=false

# SQLite file for persistent session storage (survives backend restarts).
# Sessions let users resume prior conversations from the SessionDrawer.
# Set to "memory" to disable persistence (useful for eval runs / CI).
AEGIS_SESSION_DB=aegis_sessions.db

# ─────────────────────────────────────────────
# Google Cloud / ADK (required for agent runs)
# ─────────────────────────────────────────────
# GCP project ID — used by Vertex AI (Gemini models) and Cloud Logging.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Gemini 3 models. gemini-3-flash-preview and gemini-3-pro-preview
# require "global" (not us-central1). Change only if you have a specific quota region.
GOOGLE_CLOUD_LOCATION=global

# Path to service account key (local dev only). In production use Workload Identity.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─────────────────────────────────────────────
# AlloyDB / PostgreSQL (Phase 1: migrations only; Phase 2+: live reads/writes)
# ─────────────────────────────────────────────
# AlloyDB connection string via Cloud SQL Auth Proxy (recommended).
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# For local dev with Cloud SQL Proxy: host=127.0.0.1, port=5432
ALLOYDB_URL=postgresql+asyncpg://aegis:aegis@127.0.0.1:5432/aegis_dev

# ─────────────────────────────────────────────
# Phase 2+: Lenny MCP (StartupFailurePattern ingest)
# ─────────────────────────────────────────────
# Lenny's Podcast MCP server — 284 episodes, used by Product Brain to surface
# relevant founder failure/success patterns when classifying bet risk type.
# No key needed — public server. Add to Claude Code:
#   claude mcp add -t http -s user lenny-transcripts https://lenny-mcp.onrender.com/mcp
# LENNY_MCP_URL=https://lenny-mcp.onrender.com/mcp
